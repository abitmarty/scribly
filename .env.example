APP_NAME=Scribly
APP_ENV=production
APP_KEY=base64:YOUR_KEY_HERE
APP_DEBUG=false
APP_TIMEZONE=Europe/Amsterdam
APP_URL=https://scribly.nl

APP_LOCALE=nl
APP_FALLBACK_LOCALE=nl
APP_FAKER_LOCALE=nl_NL

APP_MAINTENANCE_DRIVER=file

BCRYPT_ROUNDS=12

LOG_CHANNEL=single
LOG_LEVEL=error

# Database (MySQL on Cloud86)
DB_CONNECTION=mysql
DB_HOST=localhost
DB_PORT=3306
DB_DATABASE=scribly_db
DB_USERNAME=scribly_user
DB_PASSWORD=YOUR_PASSWORD

# Session & Cache (File-based for shared hosting)
SESSION_DRIVER=file
SESSION_LIFETIME=120
CACHE_STORE=file
FILESYSTEM_DISK=local
QUEUE_CONNECTION=sync

# Mail Configuration (Cloud86 SMTP)
MAIL_MAILER=smtp
MAIL_HOST=mail.scribly.nl
MAIL_PORT=587
MAIL_USERNAME=noreply@scribly.nl
MAIL_PASSWORD=YOUR_EMAIL_PASSWORD
MAIL_ENCRYPTION=tls
MAIL_FROM_ADDRESS=noreply@scribly.nl
MAIL_FROM_NAME=Scribly

# Admin Email (for lead notifications)
ADMIN_EMAIL=info@hetburo.digital

CACHE_STORE=database
CACHE_PREFIX=

MEMCACHED_HOST=127.0.0.1

REDIS_CLIENT=phpredis
REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379

AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-east-1
AWS_BUCKET=
AWS_USE_PATH_STYLE_ENDPOINT=false

VITE_APP_NAME="${APP_NAME}"
